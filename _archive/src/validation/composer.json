{
    "name": "hypervel/validation",
    "type": "library",
    "description": "The validation package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "validation",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Validation\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-filter": "*",
        "ext-mbstring": "*",
        "brick/math": "^0.16",
        "egulias/email-validator": "^4.0",
        "hypervel/collections": "^0.4",
        "hypervel/conditionable": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/macroable": "^0.4",
        "hypervel/support": "^0.4",
        "hypervel/translation": "^0.4"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Validation\\ValidationServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    }
}