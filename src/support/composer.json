{
    "name": "hypervel/support",
    "description": "The Support package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "support",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "require": {
        "php": "^8.4",
        "doctrine/inflector": "^2.0.5",
        "laravel/serializable-closure": "^2.0.10",
        "league/uri": "^7.5.1",
        "nesbot/carbon": "^3.8.4",
        "phpoption/phpoption": "^1.9",
        "symfony/uid": "^8.0",
        "vlucas/phpdotenv": "^5.6.1",
        "voku/portable-ascii": "^2.0.2",
        "hypervel/bus": "^0.4",
        "hypervel/collections": "^0.4",
        "hypervel/conditionable": "^0.4",
        "hypervel/config": "^0.4",
        "hypervel/console": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/events": "^0.4",
        "hypervel/filesystem": "^0.4",
        "hypervel/foundation": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/macroable": "^0.4",
        "hypervel/mail": "^0.4",
        "hypervel/notifications": "^0.4",
        "hypervel/pipeline": "^0.4",
        "hypervel/queue": "^0.4",
        "hypervel/reflection": "^0.4",
        "hypervel/view": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Support\\": "src/"
        },
        "files": [
            "src/functions.php",
            "src/helpers.php"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "suggest": {
        "ext-intl": "Required to use number formatting and spellout features."
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev"
}
