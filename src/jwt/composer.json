{
    "name": "hypervel/jwt",
    "description": "The jwt package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "jwt",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "require": {
        "php": "^8.4",
        "lcobucci/jwt": "^5.0",
        "nesbot/carbon": "^3.8.4",
        "psr/simple-cache": "^3.0",
        "hypervel/auth": "^0.4",
        "hypervel/cache": "^0.4",
        "hypervel/collections": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/support": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\JWT\\": "src/"
        }
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\JWT\\JWTServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev"
}
