{
    "name": "hypervel/socialite",
    "type": "library",
    "description": "Hypervel wrapper around OAuth 1 & OAuth 2 libraries.",
    "license": "MIT",
    "keywords": [
        "php",
        "oauth",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Socialite\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.8.2",
        "league/oauth1-client": "^1.11",
        "phpseclib/phpseclib": "^3.0",
        "hypervel/collections": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/support": "^0.4"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Socialite\\SocialiteServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    }
}