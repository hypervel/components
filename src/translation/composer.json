{
    "name": "hypervel/translation",
    "type": "library",
    "description": "The translation package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "translation",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Translation\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "hypervel/collections": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/filesystem": "^0.4",
        "hypervel/macroable": "^0.4",
        "hypervel/reflection": "^0.4",
        "hypervel/support": "^0.4"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Translation\\TranslationServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    }
}