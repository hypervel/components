{
    "name": "hypervel/devtool",
    "description": "The devtool package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "devtool",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "require": {
        "php": "^8.4",
        "hypervel/collections": "^0.4",
        "hypervel/console": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/events": "^0.4",
        "hypervel/support": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Devtool\\": "src/"
        }
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Devtool\\DevtoolServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev"
}