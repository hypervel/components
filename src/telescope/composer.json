{
    "name": "hypervel/telescope",
    "description": "The telescope package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "telescope",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        }
    ],
    "require": {
        "php": "^8.4",
        "hypervel/auth": "^0.4",
        "hypervel/broadcasting": "^0.4",
        "hypervel/bus": "^0.4",
        "hypervel/cache": "^0.4",
        "hypervel/collections": "^0.4",
        "hypervel/console": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/coroutine": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/events": "^0.4",
        "hypervel/foundation": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/http-server": "^0.4",
        "hypervel/log": "^0.4",
        "hypervel/mail": "^0.4",
        "hypervel/notifications": "^0.4",
        "hypervel/queue": "^0.4",
        "hypervel/redis": "^0.4",
        "hypervel/server": "^0.4",
        "hypervel/support": "^0.4",
        "hypervel/view": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Telescope\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4-dev"
        },
        "hypervel": {
            "providers": [
                "Hypervel\\Telescope\\TelescopeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev"
}