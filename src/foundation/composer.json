{
    "name": "hypervel/foundation",
    "description": "The Foundation package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "foundation",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/serializable-closure": "^2.0",
        "nesbot/carbon": "^2.72.6",
        "symfony/console": "^6.2|^7.0",
        "symfony/error-handler": "^6.3",
        "symfony/finder": "^7.0 || ^8.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/var-dumper": "^6.2|^7.0",
        "hypervel/auth": "^0.4",
        "hypervel/broadcasting": "^0.4",
        "hypervel/bus": "^0.4",
        "hypervel/collections": "^0.4",
        "hypervel/conditionable": "^0.4",
        "hypervel/config": "^0.4",
        "hypervel/console": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/cookie": "^0.4",
        "hypervel/coordinator": "^0.4",
        "hypervel/coroutine": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/engine": "^0.4",
        "hypervel/exception-handler": "^0.4",
        "hypervel/filesystem": "^0.4",
        "hypervel/framework": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/http-server": "^0.4",
        "hypervel/macroable": "^0.4",
        "hypervel/queue": "^0.4",
        "hypervel/reflection": "^0.4",
        "hypervel/routing": "^0.4",
        "hypervel/server": "^0.4",
        "hypervel/session": "^0.4",
        "hypervel/support": "^0.4",
        "hypervel/testing": "^0.4",
        "hypervel/validation": "^0.4",
        "hypervel/view": "^0.4",
        "hypervel/websocket-server": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Foundation\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Foundation\\Providers\\FoundationServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev"
}
