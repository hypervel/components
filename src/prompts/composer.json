{
    "name": "hypervel/prompts",
    "type": "library",
    "description": "Add beautiful and user-friendly forms to your command-line applications.",
    "license": "MIT",
    "keywords": [
        "php",
        "prompts",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "autoload": {
        "psr-4": {
            "Hypervel\\Prompts\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "composer-runtime-api": "^2.2",
        "nunomaduro/termwind": "^2.0",
        "symfony/console": "^8.0",
        "hypervel/collections": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/coroutine": "^0.4"
    },
    "require-dev": {
        "mockery/mockery": "1.6.x-dev"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
