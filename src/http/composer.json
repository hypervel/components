{
    "name": "hypervel/http",
    "type": "library",
    "description": "The http package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "swoole",
        "http",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Http\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "fruitcake/php-cors": "^1.3",
        "guzzlehttp/guzzle": "^7.8.2",
        "guzzlehttp/uri-template": "^1.0",
        "nesbot/carbon": "^2.72.6",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/mime": "^7.0 || ^8.0",
        "hypervel/collections": "^0.4",
        "hypervel/conditionable": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/macroable": "^0.4",
        "hypervel/object-pool": "^0.4",
        "hypervel/pagination": "^0.4",
        "hypervel/session": "^0.4",
        "hypervel/support": "^0.4"
    },
    "suggest": {
        "hypervel/validation": "Required for validate() method on requests."
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Http\\HttpServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    }
}
