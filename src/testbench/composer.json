{
    "name": "hypervel/testbench",
    "description": "The testbench package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "testbench",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        }
    ],
    "require": {
        "php": "^8.4",
        "mockery/mockery": "^1.6.10",
        "phpunit/phpunit": "^10.0.7",
        "symfony/yaml": "^7.3",
        "vlucas/phpdotenv": "^5.6.1",
        "hypervel/collections": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/coordinator": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/filesystem": "^0.4",
        "hypervel/foundation": "^0.4",
        "hypervel/framework": "^0.4",
        "hypervel/process": "^0.4",
        "hypervel/queue": "^0.4",
        "hypervel/routing": "^0.4",
        "hypervel/support": "^0.4"
    },
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "Hypervel\\Testbench\\": "src/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "bin": [
        "bin/testbench",
        "bin/testbench-sync"
    ],
    "scripts": {
        "sync": "@php bin/testbench-sync"
    },
    "minimum-stability": "dev"
}