{
    "name": "hypervel/routing",
    "type": "library",
    "description": "The routing package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "routing",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Routing\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "hypervel/cache": "^0.4",
        "hypervel/collections": "^0.4",
        "hypervel/conditionable": "^0.4",
        "hypervel/console": "^0.4",
        "hypervel/container": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/database": "^0.4",
        "hypervel/foundation": "^0.4",
        "hypervel/http": "^0.4",
        "hypervel/macroable": "^0.4",
        "hypervel/pipeline": "^0.4",
        "hypervel/reflection": "^0.4",
        "hypervel/session": "^0.4",
        "hypervel/support": "^0.4",
        "hypervel/view": "^0.4",
        "symfony/console": "^6.2|^7.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/psr-http-message-bridge": "^7.4|^8.0",
        "symfony/routing": "^7.0 || ^8.0"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Routing\\RoutingServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    }
}
