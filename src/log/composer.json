{
    "name": "hypervel/log",
    "type": "library",
    "description": "The log package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "log",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        },
        {
            "name": "Raj Siva-Rajah",
            "homepage": "https://github.com/binaryfire"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Log\\": "src/"
        },
        "files": [
            "src/Functions.php"
        ]
    },
    "require": {
        "php": "^8.4",
        "monolog/monolog": "^3.1",
        "psr/log": "^3.0",
        "hypervel/collections": "^0.4",
        "hypervel/config": "^0.4",
        "hypervel/context": "^0.4",
        "hypervel/contracts": "^0.4",
        "hypervel/queue": "^0.4",
        "hypervel/support": "^0.4"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hypervel": {
            "providers": [
                "Hypervel\\Log\\Context\\ContextServiceProvider",
                "Hypervel\\Log\\LogServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    }
}
